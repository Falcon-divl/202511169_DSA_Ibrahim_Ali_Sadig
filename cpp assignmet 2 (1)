#include <iostream>
using namespace std;

int main()
{
    int arr[5] = { 7,8,2,4.9};

    for (int i = 0; i < 5 - 1; i++) {
        for (int j = 0; j < 5 - 1; j++) {
            if (arr[j] > arr[j + 1]) {
                int temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
    cout << "sorted array:";
    
        for(int i = 0;i < 5;i++) {
            cout << arr[i] << "";
        }
    return 0;
}
