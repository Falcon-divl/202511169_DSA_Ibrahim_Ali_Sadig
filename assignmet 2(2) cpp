#include <iostream>
using namespace std;

int main() {
	int arr[5] = { 64,67,41,66,99 };
	int key;
	bool found = false;
	cout << "Enter number to search:";
	cin >> key;


	for (int i = 0; i < 5;i++) {
		if (arr[i] == key) {
			cout << "Found at position" << i;
			found = true;
			break;
		}
	} if (found == false) {
		cout << "Not Found ";

	}
	return 0;
}
